# Vyper Configuration
# Copy to .env and fill in your API keys

# ── AI Provider API Keys ──────────────────────────────────────
# NOTE: OpenAI & Anthropic API keys are NOT set here anymore.
# Set them via the Dashboard frontend → Settings page.
# They are stored in the Config Service container at runtime.
# Key names in Config Service: provider_openai_api_key, provider_anthropic_api_key
#
# Untuk OpenAI:   Buka http://localhost:8000/settings → isi API Key OpenAI
# Untuk Anthropic: Buka http://localhost:8000/settings → isi API Key Anthropic
# ──────────────────────────────────────────────────────────────

# Notifications (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# Webhook (optional)
WEBHOOK_SECRET=your-webhook-secret

# Immunefi (optional - uses public data)
GITHUB_TOKEN=ghp_your-github-token-for-higher-rate-limit

# Network
RPC_ENDPOINTS={"ethereum":"https://eth.llamarpc.com","arbitrum":"https://arb1.arbitrum.io/rpc","optimism":"https://mainnet.optimism.io","polygon":"https://polygon-rpc.com","avalanche":"https://api.avax.network/ext/bc/C/rpc","base":"https://mainnet.base.org"}
